---
import { browseCollection } from "../catalog/browse-loader.ts";
import BrowseCollection from "../components/BrowseCollection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Browse | Game Portal";
const description =
  "Browse every published Game Portal game by type or alphabetically without choosing party size first.";
---

<BaseLayout {title} {description} robots="index,follow" canonicalPath="/browse">
  <BrowseCollection collection={browseCollection} />
</BaseLayout>
