---
import RouteScaffold from "../components/RouteScaffold.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Browse | Game Portal";
const description =
  "Browse the curated Game Portal collection without choosing party size first. Collection content is forthcoming.";
---

<BaseLayout {title} {description}>
  <RouteScaffold
    eyebrow="Explore the collection"
    heading="Browse"
    purpose="Browse will offer a collection-first path for exploring games without setting party size."
    forthcoming="Collection indexes, categories, search, and game summaries belong to the next authorized slice."
  />
</BaseLayout>
