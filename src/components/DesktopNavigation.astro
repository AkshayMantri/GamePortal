---
import { getNavigationProjection, isCurrentRoute } from "../navigation/routes";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const primaryItems = getNavigationProjection("desktop-primary");
const personalItems = getNavigationProjection("desktop-personal");
---

<nav class="desktop-navigation" aria-label="Primary">
  <ul class="navigation-list navigation-list--primary">
    {
      primaryItems.map((item) => (
        <li>
          <a
            class="navigation-link"
            href={item.href}
            aria-current={isCurrentRoute(item, pathname) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
  <ul class="navigation-list navigation-list--personal" aria-label="Personal">
    {
      personalItems.map((item) => (
        <li>
          <a
            class="navigation-link"
            href={item.href}
            aria-current={isCurrentRoute(item, pathname) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
