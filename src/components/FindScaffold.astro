---
import { PARTY_SIZE_QUICK_CHOICES } from "../find/party-size";
import type { FindFilterOptions } from "../find/filter-options";
import FindFilterForm from "./FindFilterForm.astro";
import "../styles/find.css";

interface Props {
  options: FindFilterOptions;
}

const { options } = Astro.props;
---

<section class="find-page" aria-labelledby="find-heading">
  <header class="find-page__header">
    <p class="eyebrow">Find a game</p>
    <h1 id="find-heading">Find</h1>
    <p class="find-page__intro">
      Set up the people, time, and practical constraints for a game night. This
      milestone saves the setup in the page address; matching comes later.
    </p>
  </header>

  <fieldset
    class="party-size-control"
    data-party-size-control
    data-party-size-state="unset"
  >
    <legend>How many are playing?</legend>
    <p class="party-size-control__hint" id="party-size-hint">
      Choose a common group size, or enter any whole number from 1 to 99.
    </p>

    <div class="party-size-options" aria-describedby="party-size-hint">
      {
        PARTY_SIZE_QUICK_CHOICES.map((value) => (
          <label class="party-size-option">
            <input
              type="radio"
              name="party-size-choice"
              value={value}
              data-party-size-quick
            />
            <span>{value}</span>
          </label>
        ))
      }
      <label class="party-size-option party-size-option--custom">
        <input
          type="radio"
          name="party-size-choice"
          value="custom"
          data-party-size-custom-choice
        />
        <span>Another number</span>
      </label>
    </div>

    <div class="party-size-custom">
      <div class="party-size-custom__field">
        <label for="party-size-custom-input">Party size</label>
        <input
          id="party-size-custom-input"
          type="number"
          min="1"
          max="99"
          step="1"
          inputmode="numeric"
          autocomplete="off"
          aria-describedby="party-size-custom-hint"
          data-party-size-custom-input
        />
        <p class="party-size-custom__hint" id="party-size-custom-hint">
          Whole numbers from 1 to 99.
        </p>
        <p
          class="party-size-error"
          id="party-size-error"
          data-party-size-error
          hidden
        >
        </p>
      </div>
      <button type="button" data-party-size-apply>Apply party size</button>
    </div>
  </fieldset>

  <p class="find-page__browse">
    Prefer to explore first? <a href="/browse">Browse the collection</a>. Browse
    does not claim compatibility for the current group.
  </p>

  <section class="find-summary" aria-labelledby="find-summary-heading">
    <h2 id="find-summary-heading">Active setup</h2>
    <p data-find-empty-summary>No filters are active yet.</p>
    <div class="find-shared-link-notice" data-find-link-notice hidden>
      <p>
        Some settings in this shared link could not be used. The remaining setup
        has been restored.
      </p>
      <button type="button" data-find-link-dismiss>Dismiss notice</button>
    </div>
    <ul class="find-summary__list" data-find-summary-list hidden></ul>
    <button type="button" class="find-clear" data-find-clear hidden
      >Clear all</button
    >
  </section>

  <div class="find-filter-entry">
    <button
      type="button"
      class="find-filter-trigger"
      data-filter-open
      aria-haspopup="dialog"
      aria-controls="find-filter-dialog">More filters</button
    >
  </div>

  <div
    class="find-workspace"
    data-find-controller
    data-find-options={JSON.stringify(options)}
  >
    <div class="find-workspace__desktop" data-filter-desktop-host>
      <FindFilterForm {options} />
    </div>
    <dialog
      class="find-filter-dialog"
      id="find-filter-dialog"
      aria-labelledby="find-filter-heading"
      data-filter-dialog
    >
      <div class="find-filter-dialog__body" data-filter-dialog-host></div>
    </dialog>
  </div>

  <aside class="find-semantics" aria-labelledby="find-semantics-heading">
    <h2 id="find-semantics-heading">How this setup will be used</h2>
    <p>
      A later milestone will separate exact compatibility from uncertain data.
      Unknown information will not silently satisfy a strict filter. No games
      are matched or counted here yet.
    </p>
  </aside>

  <p
    class="party-size-live"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    data-find-live
  >
  </p>

  <noscript>
    <p class="find-noscript">
      Applying and restoring a shareable setup requires JavaScript. These labels
      remain available as preparation notes; you can also
      <a href="/browse">browse the collection</a> without setting filters.
    </p>
  </noscript>
</section>

<script src="../scripts/find-filter-controller.ts"></script>
