{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "game-portal",
  "compatibility_date": "2026-07-17",
  "assets": {
    "directory": "./dist",
    "run_worker_first": false,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "game-portal-local",
      "migrations_dir": "migrations",
      "remote": false,
    },
  ],
}
